# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- AI providers ---
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=

# --- Calendar source (pick one) ---
# Google Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# OR Microsoft Graph
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# --- Runtime ---
WMOC_LOG_LEVEL=INFO
WMOC_APPROVAL_MODE=cli   # cli | (future: slack, email)
